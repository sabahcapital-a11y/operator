{
  "name": "leadguard",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd packages/dashboard dev",
    "build": "bun run --cwd packages/dashboard build",
    "api": "bun run --cwd packages/api start",
    "db:generate": "bun run --cwd packages/db generate",
    "db:migrate": "bun run --cwd packages/db migrate",
    "db:push": "bun run --cwd packages/db push",
    "db:studio": "bun run --cwd packages/db studio",
    "runner": "bun run --cwd packages/runner start",
    "scheduler": "bun run --cwd packages/scheduler start",
    "triage": "bun run --cwd packages/triage start",
    "sample:seed": "bun run --cwd packages/db seed",
    "onboard": "bun run --cwd packages/onboard start",
    "reports": "bun run --cwd packages/reports start",
    "repair": "bun run --cwd packages/repair start",
    "pipeline": "bun run --cwd packages/onboard pipeline",
    "batch-scan": "bun run --cwd packages/onboard batch-scan",
    "generate-report": "bun run --cwd packages/onboard generate-report",
    "publish": "bun run build && bun run serve.ts",
    "go-live": "bash go-live.sh"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.7.0"
  }
}
